// ─── AI Twin Dealer ──────────────────────────────────────────────────────────
// The AI Twin is a virtual Sales Director / Business Consultant per dealer.
// One brief per dealer per day, generated nightly (or lazily on first request).

model AiTwinBrief {
  id            String   @id @default(cuid())
  dealer_id     String
  brief_date    String            // YYYY-MM-DD (dealer-local day bucket)
  health_score  Int      @default(0)
  content       Json     @default("{}")  // structured brief: greeting, highlights, plan, forecast…
  model_used    String?
  generated_by  String   @default("auto") // auto | manual | fallback
  created_at    DateTime @default(now())

  @@unique([dealer_id, brief_date])
  @@index([dealer_id, created_at])
  @@map("ai_twin_briefs")
}

model AiTwinConfig {
  id                 String   @id @default("global")
  enabled            Boolean  @default(true)
  model_alias        String   @default("sonnet")   // sonnet | haiku | opus
  brief_template     String?                        // extra instructions injected in the brief prompt
  chat_template      String?                        // extra instructions injected in the copilot prompt
  rules              Json     @default("{}")        // recommendation engine thresholds
  nightly_hour_utc   Int      @default(3)
  updated_by         String?
  updated_at         DateTime @updatedAt
  created_at         DateTime @default(now())

  @@map("ai_twin_config")
}

model AiTwinLog {
  id         String   @id @default(cuid())
  dealer_id  String?
  action     String            // brief_generated | chat | marketing | config_updated | error
  meta       Json     @default("{}")
  created_at DateTime @default(now())

  @@index([dealer_id, created_at])
  @@map("ai_twin_logs")
}

// ─── Automotive Market Data Lake ─────────────────────────────────────────────
// Proprietary historical market intelligence. APPEND-ONLY by design: every
// sync ENRICHES history (new observations / snapshots), it never overwrites.
// MarketCompetitorData above remains the "latest benchmark" cache; the lake
// below is the permanent record that grows in value with every sync.

model MarketListing {
  // The permanent internal Market Intelligence ID (mi_id = this row's id).
  id                 String    @id @default(cuid())
  source             String                     // dubizzle | dubicars | <future providers>
  fingerprint        String                     // matching key: source+make+model+year+trim+dealer (normalized)
  make               String
  model              String
  year               Int
  trim               String?
  body_type          String?
  dealer_name        String?                    // seller as observed on the source platform
  emirate            String?                    // location / free zone as observed
  country            String    @default("AE")
  source_url         String?
  first_seen_at      DateTime  @default(now())
  last_seen_at       DateTime  @default(now())
  status             String    @default("active")   // active | delisted (delisted ≈ sold/removed)
  delisted_at        DateTime?
  first_price_aed    Decimal   @db.Decimal(12,2)
  current_price_aed  Decimal   @db.Decimal(12,2)
  lowest_price_aed   Decimal   @db.Decimal(12,2)
  highest_price_aed  Decimal   @db.Decimal(12,2)
  price_changes      Int       @default(0)
  times_seen         Int       @default(1)
  lifetime_days      Int       @default(0)          // last_seen - first_seen (≈ selling time once delisted)
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  observations       MarketObservation[]

  @@unique([source, fingerprint])
  @@index([make, model, year])
  @@index([status, last_seen_at])
  @@index([dealer_name])
  @@map("market_listings")
}

model MarketObservation {
  // Append-only: one row per time a listing is observed during a sync.
  id           String   @id @default(cuid())
  listing_id   String
  run_id       String?
  observed_at  DateTime @default(now())
  price_aed    Decimal  @db.Decimal(12,2)
  status       String   @default("active")
  dealer_name  String?
  source       String
  raw          Json     @default("{}")

  listing      MarketListing @relation(fields: [listing_id], references: [id], onDelete: Cascade)

  @@index([listing_id, observed_at])
  @@index([observed_at])
  @@map("market_observations")
}

model MarketSnapshot {
  // Append-only aggregate benchmark per (make, model, year, source) per sync.
  // The historical time-series behind every trend, forecast and score.
  id               String   @id @default(cuid())
  run_id           String?
  captured_at      DateTime @default(now())
  source           String
  make             String
  model            String
  year             Int
  avg_price_aed    Decimal  @db.Decimal(12,2)
  min_price_aed    Decimal? @db.Decimal(12,2)
  max_price_aed    Decimal? @db.Decimal(12,2)
  listing_count    Int      @default(0)
  avg_days_listed  Int?
  demand_level     String?
  trend_pct        Decimal? @db.Decimal(5,2)
  confidence_pct   Int      @default(70)

  @@index([make, model, year, captured_at])
  @@index([captured_at])
  @@map("market_snapshots")
}

model MarketSyncJob {
  // Lightweight in-database queue for background Market Sync jobs.
  id            String    @id @default(cuid())
  type          String    @default("full_sync")   // full_sync | recalculate
  status        String    @default("queued")      // queued | running | success | partial | failed
  triggered_by  String?
  progress_pct  Int       @default(0)
  progress_note String?
  payload       Json      @default("{}")
  result        Json      @default("{}")
  error_detail  String?
  queued_at     DateTime  @default(now())
  started_at    DateTime?
  completed_at  DateTime?

  @@index([status, queued_at])
  @@map("market_sync_jobs")
}

model MarketLakeConfig {
  id                    String   @id @default("global")
  providers             Json     @default("[{\"key\":\"dubizzle\",\"label\":\"Dubizzle UAE\",\"enabled\":true},{\"key\":\"dubicars\",\"label\":\"DubiCars\",\"enabled\":true}]")
  retention_days        Int      @default(1825)     // 5 years of observations by default
  delist_after_days     Int      @default(21)       // active listing not seen for N days => delisted
  match_price_tolerance Int      @default(7)        // % price tolerance for intelligent listing matching
  sample_listings_per_model Int  @default(6)        // representative listings ingested per model per sync
  auto_recalculate      Boolean  @default(true)     // refresh AI indicators after each sync
  updated_by            String?
  updated_at            DateTime @updatedAt
  created_at            DateTime @default(now())

  @@map("market_lake_config")
}

model DealerProspect {
  // Known dealers across GCC free zones — the outbound prospection list.
  // Emails/phones start empty unless genuinely known: they are meant to be
  // completed by the admin (or CSV import) before inviting. status tracks
  // the funnel: prospect → invited → registered.
  id           String    @id @default(cuid())
  company_name String
  country      String    @default("AE")   // AE | SA | QA | KW | OM | BH
  emirate      String?                    // city / emirate
  free_zone    String?                    // DUCAMZ, JAFZA, SAIF Zone, ...
  email        String?
  phone        String?
  website      String?
  specialties  String?                    // e.g. "4x4 export, Japanese brands"
  status       String    @default("prospect")  // prospect | invited | registered | declined
  invited_at   DateTime?
  invite_count Int       @default(0)
  notes        String?
  source       String    @default("seed_gcc_v1")
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  @@unique([company_name, free_zone])
  @@index([status])
  @@index([country, free_zone])
  @@map("dealer_prospects")
}

model AiRecommendationStatus {
  // Persists which AI Twin recommendations a dealer has marked as done.
  // Recommendations themselves are computed fresh every time (not stored) —
  // rec_key is a stable deterministic id built from {type}:{entity_id} so a
  // "done" mark survives across brief regenerations as long as the same
  // underlying opportunity (same vehicle/lead/etc) is being recommended.
  id           String   @id @default(cuid())
  dealer_id    String
  rec_key      String
  completed_at DateTime @default(now())

  dealer Dealer @relation(fields: [dealer_id], references: [id], onDelete: Cascade)

  @@unique([dealer_id, rec_key])
  @@index([dealer_id])
  @@map("ai_recommendation_status")
}

// ─── Global Trade Intelligence Engine ────────────────────────────────────────
// Worldwide automotive-trade data lake: GCC → world export flows, routes,
// costs, regulations, and the AI layer (forecasts, opportunities, scores)
// computed on top. Seeded with a deterministic public-statistics-derived
// baseline (source='gti_seed_v1'); every additional sync enriches it.

model TradeDataSource {
  id           String    @id @default(cuid())
  name         String    @unique
  kind         String    // customs | port | shipping | marketplace | open_data
  url          String?
  status       String    @default("configured") // configured | active | error | disabled
  last_sync_at DateTime?
  notes        String?
  created_at   DateTime  @default(now())

  @@map("trade_data_sources")
}

model TradeSyncRun {
  id            String    @id @default(cuid())
  trigger       String    @default("manual") // manual | scheduled | startup_seed
  status        String    @default("running") // running | completed | failed
  flows_added   Int       @default(0)
  forecasts_built Int     @default(0)
  opportunities_built Int @default(0)
  log           String?
  started_at    DateTime  @default(now())
  finished_at   DateTime?

  @@map("trade_sync_runs")
}

model TradeFlow {
  // One historised export-flow aggregate: GCC origin → destination country,
  // per make/model/period. The raw material for every forecast.
  id               String   @id @default(cuid())
  period           DateTime // month bucket
  origin_country   String   // AE | SA | QA | OM | BH | KW
  dest_country     String   // ISO-2
  dest_region      String?  // Africa | CIS | South Asia | ...
  make             String?
  model            String?
  category         String?  // SUV | Sedan | Pickup | Luxury
  units            Int      @default(0)
  avg_price_aed    Int?
  source           String   @default("gti_seed_v1")
  created_at       DateTime @default(now())

  @@index([origin_country, dest_country, period])
  @@index([make, model])
  @@map("trade_flows")
}

model TradeRoute {
  id                 String  @id @default(cuid())
  origin_port        String  // e.g. Jebel Ali
  origin_country     String
  dest_port          String
  dest_country       String
  shipping_lines     String[] // carriers serving the route
  transit_days_avg   Int
  frequency_per_month Int    @default(4)
  cost_per_unit_aed  Int     // RoRo per-vehicle average
  insurance_pct      Float   @default(1.5)
  source             String  @default("gti_seed_v1")
  updated_at         DateTime @updatedAt

  @@unique([origin_port, dest_port])
  @@index([dest_country])
  @@map("trade_routes")
}

model CountryTradeProfile {
  id                 String  @id @default(cuid())
  country            String  @unique // ISO-2
  country_name       String
  region             String
  import_duty_pct    Float   @default(0)
  vat_pct            Float   @default(0)
  other_fees_aed     Int     @default(0)
  max_vehicle_age    Int?    // import age restriction in years, null = none
  drive_side         String  @default("LHD") // LHD | RHD
  regulations        String? // human-readable summary
  restrictions       String?
  demand_categories  String[] // hot categories
  market_growth_pct  Float   @default(0)  // YoY trend
  risk_score         Int     @default(50) // 0 (safe) - 100 (risky)
  updated_at         DateTime @updatedAt

  @@map("country_trade_profiles")
}

model TradeForecast {
  id             String   @id @default(cuid())
  run_id         String?
  dest_country   String
  make           String?
  model          String?
  horizon_months Int      // 3 | 6 | 12
  demand_index   Int      // 0-100
  price_trend_pct Float
  logistics_cost_trend_pct Float
  transit_trend_days Float @default(0)
  confidence_pct Int      @default(70)
  computed_at    DateTime @default(now())

  @@index([dest_country, horizon_months])
  @@map("trade_forecasts")
}

model TradeOpportunity {
  id               String   @id @default(cuid())
  run_id           String?
  dest_country     String
  make             String?
  model            String?
  category         String?
  kind             String   @default("export") // export | arbitrage | emerging_market
  headline         String
  rationale        String?
  profitability_score Int   @default(50)
  risk_score       Int      @default(50)
  competition_score Int     @default(50)
  est_margin_pct   Float?
  active           Boolean  @default(true)
  computed_at      DateTime @default(now())

  @@index([active, profitability_score])
  @@map("trade_opportunities")
}

model DealerGtiAccess {
  // Admin-controlled premium gate for the dealer-facing GTI tab.
  id          String   @id @default(cuid())
  dealer_id   String   @unique
  enabled     Boolean  @default(true)
  granted_by  String?  // admin user id
  note        String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("dealer_gti_access")
}

