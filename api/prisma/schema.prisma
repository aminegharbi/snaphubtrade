generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  password_hash   String?
  full_name       String
  phone           String?
  whatsapp        String?
  avatar_url      String?
  role            String    @default("buyer")
  mfa_secret      String?
  mfa_enabled     Boolean   @default(false)
  email_verified  Boolean   @default(false)
  preferred_lang  String    @default("en")
  last_login_at   DateTime?
  password_reset_token   String?   @unique
  password_reset_expires DateTime?
  google_id       String?   @unique // set when the account was created/linked via Google Sign-In
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  dealers         Dealer[]
  lead_activities LeadActivity[]
  price_history   PriceHistory[]
  dealer_reviews  DealerReview[]
  favorites       Favorite[]

  @@map("users")
}

// ─── GCC countries & free zones (multi-country support) ───────────────────────
// Structured replacement for what used to be a hardcoded UAE-only zones list
// on the dealers endpoint, and a free-text-only `free_zone_license` field on
// Dealer. Countries/zones are seeded data (postgres/06_gcc_countries.sql),
// editable by admin later if needed — not hardcoded in application code.
model Country {
  id            String   @id @default(cuid())
  code          String   @unique @db.VarChar(2)  // ISO 3166-1 alpha-2: AE, SA, QA, BH, KW, OM
  name          String                            // English name
  name_ar       String?                           // Arabic name
  currency_code String   @db.VarChar(3)           // ISO 4217: AED, SAR, QAR, BHD, KWD, OMR
  phone_prefix  String                            // +971, +966, +974, +973, +965, +968
  vat_rate      Decimal  @default(0) @db.Decimal(4,3) // e.g. 0.05 = 5% — was hardcoded to UAE's 5% everywhere
  is_active     Boolean  @default(true)            // allows disabling a market without deleting data
  created_at    DateTime @default(now())

  free_zones    FreeZone[]
  dealers       Dealer[]
  brokers       Broker[]

  @@map("countries")
}

model FreeZone {
  id          String   @id @default(cuid())
  country_id  String
  name        String                              // e.g. "Jebel Ali Free Zone (JAFZA)"
  code        String                              // short code, e.g. "jafza"
  city        String?                             // e.g. "Dubai"
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())

  country     Country  @relation(fields: [country_id], references: [id])
  dealers     Dealer[]

  @@unique([country_id, code])
  @@map("free_zones")
}

model Dealer {
  id                  String   @id @default(cuid())
  user_id             String?
  company_name        String
  slug                String   @unique
  description         String?
  logo_url            String?
  cover_url           String?
  phone               String?
  whatsapp            String?
  email               String?
  website             String?
  address             String?
  city                String?
  country_id          String?
  free_zone_id        String?
  free_zone_license   String?  // the license NUMBER — distinct from which free zone (structured, above)
  languages           String[]
  export_destinations String[]
  certifications      String[]
  verified            Boolean  @default(false)
  verified_at         DateTime?
  rating              Decimal  @default(0) @db.Decimal(3,2)
  review_count        Int      @default(0)
  subscription_tier   String   @default("free")
  subscription_ends   DateTime?
  stripe_customer_id  String?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  user                User?          @relation(fields: [user_id], references: [id])
  country             Country?       @relation(fields: [country_id], references: [id])
  free_zone           FreeZone?      @relation(fields: [free_zone_id], references: [id])
  vehicles            Vehicle[]
  leads               Lead[]
  reviews             DealerReview[]
  owned_shares        VehicleShare[]        @relation("owned_shares")
  granted_permissions SharePermission[]     @relation("granted_permissions")
  notifications       Notification[]
  subscriptions       DealerSubscription[]
  ai_recommendation_status AiRecommendationStatus[]
  broker_deals        BrokerDeal[]
  reports             DealerReport[]
  reservations        VehicleReservation[]
  quotes              Quote[]
  invoices            Invoice[]

  @@index([country_id])
  @@index([free_zone_id])
  @@map("dealers")
}

model DealerReview {
  id         String   @id @default(cuid())
  dealer_id  String
  user_id    String?
  rating     Int
  comment    String?
  created_at DateTime @default(now())

  dealer     Dealer   @relation(fields: [dealer_id], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [user_id], references: [id])

  @@map("dealer_reviews")
}

model Vehicle {
  id                  String   @id @default(cuid())
  dealer_id           String
  vin                 String?
  plate_number        String?
  stock_quantity      Int      @default(1)
  sold_units          Int      @default(0)
  specs_origin        String   @default("GCC")
  make                String
  model               String
  year                Int
  generation          String?
  trim                String?
  body_type           String?
  fuel_type           String?
  transmission        String?
  engine              String?
  horsepower          Int?
  torque              Int?
  doors               Int?
  seats               Int?
  mileage_km          Int      @default(0)
  color_exterior      String?
  color_interior      String?
  wheels              String?
  country_origin      String?
  specs               Json     @default("{}")
  features            String[]
  price_aed           Decimal  @db.Decimal(12,2)
  price_min_aed       Decimal? @db.Decimal(12,2)
  price_suggested_aed Decimal? @db.Decimal(12,2)
  // The actual currency this listing's price is denominated in — set from the
  // dealer's country at creation time (vehicles.service.ts). The `_aed`
  // column names are now historical/legacy (kept for schema stability) —
  // always read `currency` to know the real unit, never assume AED.
  currency            String   @default("AED")
  negotiable          Boolean  @default(true)
  status              String   @default("available")
  export_eligible     Boolean  @default(false)
  title               String?
  description         String?
  seo_keywords        String?
  ai_confidence       Decimal? @db.Decimal(4,3)
  ai_raw_result       Json?
  duplicate_hash      String?
  view_count          Int      @default(0)
  favorite_count      Int      @default(0)
  es_indexed_at       DateTime?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  dealer          Dealer         @relation(fields: [dealer_id], references: [id], onDelete: Cascade)
  vehicle_images  VehicleImage[]
  price_history   PriceHistory[]
  leads           Lead[]
  promotions      Promotion[]
  favorites         Favorite[]
  shares            VehicleShare[]
  timeline          VehicleTimeline[]
  collaboration_msgs CollaborationMessage[]
  qr_code           VehicleQrCode?
  stock_transactions StockTransaction[]
  valuations         VehicleValuation[]
  reservations        VehicleReservation[]
  quotes             Quote[]
  invoices           Invoice[]

  @@map("vehicles")
}

model VehicleImage {
  id          String   @id @default(cuid())
  vehicle_id  String
  s3_key      String
  cdn_url     String?
  thumb_url   String?
  is_primary  Boolean  @default(false)
  position    Int      @default(0)
  created_at  DateTime @default(now())

  vehicle     Vehicle  @relation(fields: [vehicle_id], references: [id], onDelete: Cascade)

  @@map("vehicle_images")
}

model PriceHistory {
  id          String   @id @default(cuid())
  vehicle_id  String
  price_aed   Decimal  @db.Decimal(12,2)
  changed_by  String?
  changed_at  DateTime @default(now())

  vehicle     Vehicle  @relation(fields: [vehicle_id], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [changed_by], references: [id])

  @@map("price_history")
}

model Lead {
  id              String   @id @default(cuid())
  dealer_id       String
  vehicle_id      String?
  buyer_name      String?
  buyer_email     String?
  buyer_phone     String?
  buyer_whatsapp  String?
  stage           String   @default("new")
  channel         String   @default("website")
  notes           String?
  offer_price     Decimal? @db.Decimal(12,2)
  source_url      String?
  // Dealer response to this request (Accept / Counter / Reject) — set once the
  // dealer acts on the buyer's request; keeps the original offer_price intact
  // as the buyer's ask, and records the dealer's side separately.
  dealer_decision      String?   // accepted | rejected | countered
  dealer_counter_price Decimal?  @db.Decimal(12,2)
  dealer_response_note String?
  responded_at         DateTime?
  responded_by         String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  dealer          Dealer        @relation(fields: [dealer_id], references: [id], onDelete: Cascade)
  vehicle         Vehicle?      @relation(fields: [vehicle_id], references: [id])
  activities      LeadActivity[]

  @@map("leads")
}

model LeadActivity {
  id          String   @id @default(cuid())
  lead_id     String
  type        String
  note        String?
  created_by  String?
  created_at  DateTime @default(now())

  lead        Lead     @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [created_by], references: [id])

  @@map("lead_activities")
}

model Promotion {
  id              String   @id @default(cuid())
  dealer_id       String?
  vehicle_id      String
  type            String   @default("price_reduction")
  original_price  Decimal  @db.Decimal(12,2)
  promo_price     Decimal  @db.Decimal(12,2)
  label           String?
  starts_at       DateTime @default(now())
  ends_at         DateTime?
  active          Boolean  @default(true)
  created_at      DateTime @default(now())

  vehicle         Vehicle  @relation(fields: [vehicle_id], references: [id], onDelete: Cascade)

  @@map("promotions")
}

model Favorite {
  user_id    String
  vehicle_id String
  created_at DateTime @default(now())

  user       User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  vehicle    Vehicle @relation(fields: [vehicle_id], references: [id], onDelete: Cascade)

  @@id([user_id, vehicle_id])
  @@map("favorites")
}

model VehicleShare {
  id              String   @id @default(cuid())
  vehicle_id      String
  owner_dealer_id String
  visibility      String   @default("private")
  group_id        String?
  active          Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  vehicle         Vehicle           @relation(fields: [vehicle_id], references: [id], onDelete: Cascade)
  owner           Dealer            @relation("owned_shares", fields: [owner_dealer_id], references: [id], onDelete: Cascade)
  permissions     SharePermission[]
  broker_permissions BrokerSharePermission[]

  @@map("vehicle_shares")
}

model BrokerSharePermission {
  // Broker-facing counterpart of SharePermission — kept as its own table
  // (rather than making SharePermission.dealer_id nullable) so the existing
  // dealer-to-dealer sharing flow is completely untouched. Same permission
  // shape (can_view/can_propose/can_reserve/can_transfer/can_negotiate) so a
  // dealer can extend the exact same controls to brokers in their network.
  id             String    @id @default(cuid())
  share_id       String
  broker_id      String
  can_view       Boolean   @default(true)
  can_propose    Boolean   @default(false)
  can_reserve    Boolean   @default(false)
  can_transfer   Boolean   @default(false)
  can_negotiate  Boolean   @default(false)
  starts_at      DateTime  @default(now())
  ends_at        DateTime?
  revoked_at     DateTime?
  revoked_by     String?
  created_at     DateTime  @default(now())

  share          VehicleShare @relation(fields: [share_id], references: [id], onDelete: Cascade)
  broker         Broker       @relation(fields: [broker_id], references: [id], onDelete: Cascade)

  @@unique([share_id, broker_id])
  @@map("broker_share_permissions")
}

model SharePermission {
  id             String    @id @default(cuid())
  share_id       String
  dealer_id      String
  can_view       Boolean   @default(true)
  can_propose    Boolean   @default(false)
  can_reserve    Boolean   @default(false)
  can_transfer   Boolean   @default(false)
  can_negotiate  Boolean   @default(false)
  starts_at      DateTime  @default(now())
  ends_at        DateTime?
  revoked_at     DateTime?
  revoked_by     String?
  created_at     DateTime  @default(now())

  share          VehicleShare @relation(fields: [share_id], references: [id], onDelete: Cascade)
  dealer         Dealer       @relation("granted_permissions", fields: [dealer_id], references: [id], onDelete: Cascade)

  @@unique([share_id, dealer_id])
  @@map("share_permissions")
}

model DealerGroup {
  id          String   @id @default(cuid())
  name        String
  description String?
  created_by  String?
  created_at  DateTime @default(now())

  members     DealerGroupMember[]

  @@map("dealer_groups")
}

model DealerGroupMember {
  group_id  String
  dealer_id String
  role      String   @default("member")
  joined_at DateTime @default(now())

  group     DealerGroup @relation(fields: [group_id], references: [id], onDelete: Cascade)

  @@id([group_id, dealer_id])
  @@map("dealer_group_members")
}

model VehicleTimeline {
  id          String   @id @default(cuid())
  vehicle_id  String
  event_type  String
  event_data  Json     @default("{}")
  actor_id    String?
  actor_type  String   @default("dealer")
  note        String?
  occurred_at DateTime @default(now())

  vehicle     Vehicle  @relation(fields: [vehicle_id], references: [id], onDelete: Cascade)

  @@map("vehicle_timeline")
}

model CollaborationMessage {
  id              String    @id @default(cuid())
  vehicle_id      String
  from_dealer_id  String?
  to_dealer_id    String?
  from_broker_id  String?
  to_broker_id    String?
  msg_type        String
  content         String?
  offer_price_aed Decimal?  @db.Decimal(12,2)
  status          String    @default("pending")
  expires_at      DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  vehicle         Vehicle   @relation(fields: [vehicle_id], references: [id], onDelete: Cascade)

  @@map("collaboration_messages")
}

model ScanEvent {
  id           String    @id @default(cuid())
  vehicle_id   String?
  dealer_id    String?
  scan_type    String
  scan_data    String?
  action_taken String?
  source       String    @default("mobile")
  lat          Decimal?  @db.Decimal(10,7)
  lng          Decimal?  @db.Decimal(10,7)
  scanned_at   DateTime  @default(now())

  @@map("scan_events")
}

model VehicleQrCode {
  id         String   @id @default(cuid())
  vehicle_id String   @unique
  qr_token   String   @unique @default(cuid())
  qr_url     String?
  created_at DateTime @default(now())

  vehicle    Vehicle  @relation(fields: [vehicle_id], references: [id], onDelete: Cascade)

  @@map("vehicle_qr_codes")
}

model Notification {
  id         String    @id @default(cuid())
  dealer_id  String?
  broker_id  String?
  type       String
  category   String    @default("general")
  // 'reservation' | 'shared_stock' | 'sale' | 'lead' | 'broker_deal' | 'general'
  title      String
  body       String?
  data       Json      @default("{}")
  read_at    DateTime?
  created_at DateTime  @default(now())

  dealer     Dealer?   @relation(fields: [dealer_id], references: [id], onDelete: Cascade)
  broker     Broker?   @relation(fields: [broker_id], references: [id], onDelete: Cascade)

  @@index([dealer_id, read_at])
  @@index([broker_id, read_at])
  @@map("notifications")
}

// ─── SaaS Subscription System ────────────────────────────────────────────────

model SubscriptionPlan {
  id                       String   @id @default(cuid())
  name                     String
  slug                     String   @unique
  description              String?
  tagline                  String?
  color                    String   @default("#6B7280")
  badge                    String?
  is_active                Boolean  @default(true)
  is_visible               Boolean  @default(true)
  sort_order               Int      @default(0)
  price_monthly            Decimal  @default(0)  @db.Decimal(10,2)
  price_quarterly          Decimal  @default(0)  @db.Decimal(10,2)
  price_yearly             Decimal  @default(0)  @db.Decimal(10,2)
  currency                 String   @default("AED")
  trial_days               Int      @default(0)
  stripe_price_monthly_id  String?
  stripe_price_yearly_id   String?
  created_at               DateTime @default(now())
  updated_at               DateTime @updatedAt

  features      PlanFeature[]
  limits        PlanLimit[]
  subscriptions DealerSubscription[]

  @@map("subscription_plans")
}

model SubscriptionFeature {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  icon        String?
  category    String   @default("general")
  is_active   Boolean  @default(true)
  is_premium  Boolean  @default(false)
  is_visible  Boolean  @default(true)
  sort_order  Int      @default(0)
  created_at  DateTime @default(now())

  plan_features PlanFeature[]

  @@map("subscription_features")
}

model PlanFeature {
  id          String   @id @default(cuid())
  plan_id     String
  feature_id  String
  enabled     Boolean  @default(true)
  limit_value Int?
  created_at  DateTime @default(now())

  plan    SubscriptionPlan    @relation(fields: [plan_id], references: [id], onDelete: Cascade)
  feature SubscriptionFeature @relation(fields: [feature_id], references: [id], onDelete: Cascade)

  @@unique([plan_id, feature_id])
  @@map("plan_features")
}

model PlanLimit {
  id          String @id @default(cuid())
  plan_id     String
  limit_key   String
  limit_name  String
  limit_value Int    @default(0)
  created_at  DateTime @default(now())

  plan SubscriptionPlan @relation(fields: [plan_id], references: [id], onDelete: Cascade)

  @@unique([plan_id, limit_key])
  @@map("plan_limits")
}

model DealerSubscription {
  id                     String    @id @default(cuid())
  dealer_id              String
  plan_id                String
  status                 String    @default("active")
  billing_cycle          String    @default("monthly")
  current_period_start   DateTime  @default(now())
  current_period_end     DateTime?
  trial_start            DateTime?
  trial_end              DateTime?
  cancelled_at           DateTime?
  cancel_reason          String?
  auto_renew             Boolean   @default(true)
  stripe_subscription_id String?
  stripe_customer_id     String?
  coupon_id              String?
  discount_pct           Int       @default(0)
  grace_period_ends      DateTime?
  created_at             DateTime  @default(now())
  updated_at             DateTime  @updatedAt

  dealer   Dealer           @relation(fields: [dealer_id], references: [id], onDelete: Cascade)
  plan     SubscriptionPlan @relation(fields: [plan_id], references: [id])
  invoices SubscriptionInvoice[]
  history  SubscriptionHistory[]

  @@map("dealer_subscriptions")
}

model SubscriptionInvoice {
  id              String    @id @default(cuid())
  subscription_id String
  dealer_id       String
  invoice_number  String    @unique
  status          String    @default("draft")
  amount_subtotal Decimal   @db.Decimal(10,2)
  amount_discount Decimal   @default(0) @db.Decimal(10,2)
  amount_tax      Decimal   @default(0) @db.Decimal(10,2)
  amount_total    Decimal   @db.Decimal(10,2)
  currency        String    @default("AED")
  billing_cycle   String?
  period_start    DateTime?
  period_end      DateTime?
  paid_at         DateTime?
  due_date        DateTime?
  stripe_invoice_id String?
  pdf_url         String?
  created_at      DateTime  @default(now())

  subscription DealerSubscription   @relation(fields: [subscription_id], references: [id])
  payments     SubscriptionPayment[]

  @@map("subscription_invoices")
}

model SubscriptionPayment {
  id                 String    @id @default(cuid())
  invoice_id         String
  dealer_id          String
  amount             Decimal   @db.Decimal(10,2)
  currency           String    @default("AED")
  status             String    @default("pending")
  gateway            String    @default("stripe")
  gateway_payment_id String?
  gateway_response   Json      @default("{}")
  failure_reason     String?
  refunded_at        DateTime?
  created_at         DateTime  @default(now())

  invoice SubscriptionInvoice @relation(fields: [invoice_id], references: [id])

  @@map("subscription_payments")
}

model SubscriptionCoupon {
  id              String    @id @default(cuid())
  code            String    @unique
  name            String?
  discount_type   String    @default("percentage")
  discount_value  Decimal   @db.Decimal(10,2)
  max_uses        Int?
  current_uses    Int       @default(0)
  valid_from      DateTime  @default(now())
  valid_until     DateTime?
  min_amount      Decimal   @default(0) @db.Decimal(10,2)
  applicable_plans String[]
  is_active       Boolean   @default(true)
  created_at      DateTime  @default(now())

  @@map("subscription_coupons")
}

model SubscriptionUsage {
  id           String   @id @default(cuid())
  dealer_id    String
  usage_key    String
  period_year  Int
  period_month Int
  value        Int      @default(0)
  reset_at     DateTime?
  updated_at   DateTime @updatedAt

  @@unique([dealer_id, usage_key, period_year, period_month])
  @@map("subscription_usage")
}

model SubscriptionHistory {
  id              String   @id @default(cuid())
  dealer_id       String
  subscription_id String?
  event_type      String
  from_plan_id    String?
  to_plan_id      String?
  metadata        Json     @default("{}")
  created_at      DateTime @default(now())

  subscription DealerSubscription? @relation(fields: [subscription_id], references: [id])

  @@map("subscription_history")
}

model AiCredit {
  id               String    @id @default(cuid())
  dealer_id        String    @unique
  credits_total    Int       @default(0)
  credits_used     Int       @default(0)
  credits_reset_at DateTime?
  reset_period     String    @default("monthly")
  updated_at       DateTime  @updatedAt

  @@map("ai_credits")
}

model StockTransaction {
  id              String   @id @default(cuid())
  vehicle_id      String
  dealer_id       String?
  txn_type        String
  quantity        Int      @default(1)
  quantity_before Int      @default(0)
  quantity_after  Int      @default(0)
  note            String?
  actor_id        String?
  source          String   @default("manual")
  occurred_at     DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicle_id], references: [id], onDelete: Cascade)

  @@map("stock_transactions")
}

// ─── Catalog tables (managed by raw SQL, declared here to prevent drop) ──────


// ─── Broker & Affiliate System ────────────────────────────────────────────────

model Broker {
  id              String   @id @default(cuid())
  user_id         String?
  full_name       String
  email           String   @unique
  phone           String?
  whatsapp        String?
  company_name    String?
  broker_type     String   @default("independent")
  affiliate_code  String   @unique
  tier            String   @default("Starter")
  commission_rate Decimal  @default(0.015) @db.Decimal(4,3)
  status          String   @default("pending")
  country         String?  // free-text legacy field — kept for backward compatibility
  country_id      String?  // structured GCC country — use this for new logic/filtering
  city            String?
  languages       String[]
  specialties     String[]
  referred_by     String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  country_ref        Country?             @relation(fields: [country_id], references: [id])
  deals              BrokerDeal[]
  referrals          BrokerReferral[]
  reservations       VehicleReservation[]
  notifications      Notification[]
  affiliatePayments  AffiliatePayment[]
  shared_inventory_permissions BrokerSharePermission[]

  @@index([country_id])
  @@map("brokers")
}

model BrokerDeal {
  id              String    @id @default(cuid())
  broker_id       String
  dealer_id       String
  vehicle_id      String?
  buyer_name      String?
  buyer_country   String?
  deal_price_aed  Decimal   @db.Decimal(12,2)
