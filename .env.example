# ═══════════════════════════════════════════════════════════════════════════════
# DubaiAuto — Environment Variables
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=dubaiauto
# Use a strong, unique password in any non-local environment.
POSTGRES_PASSWORD=change-me-use-a-long-random-password
POSTGRES_DB=dubaiauto

# ── Réplication (read replica / "slave") ───────────────────────────────────────
# Dedicated password for the replication role — must differ from POSTGRES_PASSWORD.
# See postgres/BACKUP_RESTORE.md for setup, restore and failover procedures.
POSTGRES_REPLICA_PASSWORD=change-me-use-a-different-long-random-password

# ── Sauvegardes automatiques ────────────────────────────────────────────────────
# Cron-style schedule (see https://crontab.guru), retention counts.
BACKUP_SCHEDULE=@daily
BACKUP_KEEP_DAYS=7
BACKUP_KEEP_WEEKS=4
BACKUP_KEEP_MONTHS=6

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-long-random-string-64-chars

# ── First admin account (bootstrapped automatically on container start) ───────
# Required to access /admin at all — there is no other way to create an admin
# account (public registration can never set role=admin). Leave both empty to
# skip bootstrap (e.g. once you already have an admin and don't want this
# running on every deploy). Set ADMIN_FORCE_RESET=1 only for a genuine
# break-glass password reset — it overwrites the existing admin's password.
ADMIN_EMAIL=admin@dubaiauto.ae
ADMIN_PASSWORD=change-me-strong-password-min-12-chars
ADMIN_FULL_NAME=Platform Admin
ADMIN_FORCE_RESET=0

# ── E2E test suite only (robot-tests) — leave EMPTY in every real deployment ──
# Optional shared secret that lets the Robot Framework suite bypass auth rate
# limits (5 registrations/min, 8 logins/min per IP) it would otherwise trip by
# creating dozens of throw-away fixture accounts. When set here, restart the
# API (docker compose up -d --force-recreate api) for it to take effect, then
# run ./run-tests.sh. Use a random value, never a memorable one, and remove it
# again (or rotate it) once you're done testing.
TEST_BYPASS_TOKEN=

# ── Security ──────────────────────────────────────────────────────────────────
# Comma-separated list of front-end origins allowed to call the API with credentials.
# With the default docker-compose setup (nginx on port 80), the browser origin
# is "http://localhost" — NOT "http://localhost:3000". Add your real domain(s)
# here for production, e.g. ALLOWED_ORIGINS=https://dubaiauto.ae,https://www.dubaiauto.ae
ALLOWED_ORIGINS=http://localhost,http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# IA PROVIDER — choisir UNE option parmi les deux ci-dessous
# ─────────────────────────────────────────────────────────────────────────────

# ── Option A : Anthropic Direct (défaut) ─────────────────────────────────────
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-api03-...your-key-here...
# Modèles utilisés : claude-sonnet-4-6 + claude-haiku-4-5-20251001

# ── Option B : Google Cloud Vertex AI + Claude ────────────────────────────────
# Décommenter les lignes suivantes et commenter l'Option A
#
# AI_PROVIDER=vertex
# VERTEX_PROJECT_ID=mon-projet-gcp
# VERTEX_REGION=us-east5
#   Régions disponibles : us-east5, europe-west1, europe-west4,
#                         asia-southeast1, us-central1
#
# Authentification — choisir une des deux méthodes :
#   Méthode 1 (recommandée) : Service Account JSON
#   → Créer un SA sur GCP Console → IAM → Comptes de service
#   → Rôles requis : "Vertex AI User" + "ML Developer"
#   → Télécharger le JSON et le placer dans dubaiauto/api/config/
#   GOOGLE_APPLICATION_CREDENTIALS=/app/config/service-account.json
#
#   Méthode 2 : Application Default Credentials (si déployé sur GCP)
#   → Rien à configurer, ADC est automatique sur GCE/GKE/Cloud Run
#
# Modèles utilisés sur Vertex : claude-sonnet-4-5@20251001 + claude-haiku-4-5@20251001
# ─────────────────────────────────────────────────────────────────────────────

# ── AWS S3 (optionnel — stockage photos) ─────────────────────────────────────
# Sans ces clés, les images sont stockées localement dans /app/uploads
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# AWS_REGION=me-south-1
# AWS_S3_BUCKET=dubaiauto-vehicles
# CDN_BASE_URL=https://cdn.tondomaine.com

# ── Stripe (optionnel — paiements abonnements) ────────────────────────────────
# Sans ces clés, les plans payants refusent proprement le paiement au lieu de
# s'activer gratuitement (seuls les plans gratuits fonctionnent sans Stripe).
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Configure ce endpoint comme webhook dans le Dashboard Stripe :
#   https://tondomaine.com/api/v1/subscription/webhook/stripe
# Événements à écouter : checkout.session.completed, invoice.payment_failed,
# customer.subscription.deleted

# ── App ───────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# ── Google Sign-In (optionnel) ─────────────────────────────────────────────────
# Sans cette clé, le bouton "Continue with Google" reste invisible et
# /auth/google refuse proprement. Pour l'activer :
#   1. console.cloud.google.com → APIs & Services → Credentials
#   2. Créer un "OAuth client ID" de type "Web application"
#   3. Ajouter ton domaine dans "Authorized JavaScript origins"
#      (ex: https://tondomaine.com)
#   4. Coller le Client ID ci-dessous (PAS le Client Secret — inutile ici)
# ⚠️ Après avoir renseigné cette valeur, il faut rebuild l'image web
# (docker compose build web) — un simple restart ne suffit pas, cette
# variable est figée dans le bundle JS au moment du build.
GOOGLE_CLIENT_ID=

# ── Email Provider (Module 2: Email Marketing) ────────────────────────────────
# Pick ONE:
EMAIL_PROVIDER=console          # console | resend | sendgrid

# Resend (recommended — free tier: 3,000 emails/month, resend.com)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# SendGrid
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxx

# Sender identity
# EMAIL_FROM=noreply@dubaiauto.ae
